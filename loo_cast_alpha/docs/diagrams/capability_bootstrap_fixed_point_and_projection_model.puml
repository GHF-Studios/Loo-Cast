@startuml
!theme plain
title Capability/API Bootstrap Fixed-Point and Projection Model (Draft)

skinparam shadowing false
skinparam packageStyle rectangle

package "Host Authority (Rust)" {
  rectangle "Dynamic Module Load\n(dll/so/dylib)" as LOAD
  rectangle "Reflection Registration\n(Macro Metadata -> Registry)" as REFLECT
  rectangle "Global Capability/API Graph\n(Unrestricted Host Graph)" as GLOBAL
}

package "Profile/Projection Meta-Layer" {
  rectangle "Capability Profile Graph\n(Nestable/Composite)" as PROFILE
  rectangle "Projection Planning\n(Whitelist default,\noptional blacklist override)" as PLAN
  rectangle "Projection Instantiation\n(decl_ctx / cb_ctx / ...)" as PROJECT
}

package "Script Layer (Rhai)" {
  rectangle "Declaration Entrypoints" as DECL
  rectangle "Callback Closures" as CB
}

package "Bootstrap Resolution Loop" {
  rectangle "Resolve Layer\n(Topology-Derived, Strict)" as RESOLVE
  rectangle "Validate + Materialize" as MATERIALIZE
  rectangle "Merge into Host Graph" as MERGE
  diamond "Fixed Point\nReached?" as FIXED
}

rectangle "Runtime Lock" as LOCK
rectangle "Runtime Evolution Loop" as EVOLVE

LOAD --> REFLECT --> GLOBAL
GLOBAL --> PROFILE --> PLAN --> PROJECT

PROJECT --> DECL
PROJECT --> CB

DECL --> RESOLVE
RESOLVE --> MATERIALIZE --> MERGE --> GLOBAL
MERGE --> FIXED
FIXED --> RESOLVE : no
FIXED --> LOCK : yes
LOCK --> EVOLVE

note right of RESOLVE
First-order declaration profiles
cannot depend on other capabilities.
Dependency cycles are invalid.
end note

note right of PROJECT
Projected facades are script-safe.
Raw global graph access is script-unsafe.
end note

@enduml
