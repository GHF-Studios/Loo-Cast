@startuml
title SDK Architecture & Toolchain Authority (Vendored Canonical Build Model)
left to right direction

' =========================
' DARK MODE REVIEW THEME
' =========================

skinparam backgroundColor #121417
skinparam shadowing false
skinparam defaultFontName JetBrains Mono
skinparam defaultFontColor #f3f5f7
skinparam linetype polyline
skinparam componentStyle rectangle
skinparam nodesep 70
skinparam ranksep 90

skinparam component {
  BackgroundColor #26313c
  BorderColor #7c8b9b
  FontColor #ffffff
  RoundCorner 10
  BackgroundColor<<Authority>> #234057
  BorderColor<<Authority>> #77b7e8
  BackgroundColor<<Bundle>> #3a2f44
  BorderColor<<Bundle>> #b492d8
  BackgroundColor<<Execution>> #2f3f2a
  BorderColor<<Execution>> #96c37a
  BackgroundColor<<Guard>> #3a3528
  BorderColor<<Guard>> #d6c57f
  BackgroundColor<<Artifact>> #3a2f2a
  BorderColor<<Artifact>> #e5b77d
}

skinparam package {
  BackgroundColor #1b2128
  BorderColor #5f6a75
  FontColor #ffffff
}

skinparam actor {
  BackgroundColor #2b3742
  BorderColor #98a7b8
  FontColor #ffffff
}

skinparam note {
  BackgroundColor #2a3138
  BorderColor #8b98a6
  FontColor #f3f5f7
}

skinparam ArrowColor #79b8ff
skinparam ArrowFontColor #f3f5f7

actor "Root Developer" as RootDev
actor "Mod Developer" as ModDev

package "Root Dev Authority Domain" #1f2b36 {
  component "Pinned Toolchain Manifest\n(rustc + cargo + targets + deps)" as ToolchainManifest <<Authority>>
  component "SDK Source Set\n(sdk_cli + core_engine + core_mod)" as SDKSource <<Authority>>
  component "SDK Bundle Builder" as BundleBuilder <<Guard>>
}

package "Distributed SDK Bundle" #2c2438 {
  component "Vendored Toolchain Payload" as VendoredToolchain <<Bundle>>
  component "Contract Templates" as ContractTemplates <<Bundle>>
  component "Mod Templates" as ModTemplates <<Bundle>>
  component "Local DAG Validator" as LocalValidator <<Bundle>>
  component "Local Provenance Preview CLI\n(non-authoritative)" as ProvenanceCLI <<Bundle>>
  component "Namespace Ownership Mapping CLI\n(GitHub + Steam helper)" as OwnershipMapCLI <<Bundle>>
}

package "Mod Developer Workspace" #24372d {
  component "Local Build + Validation\n(non-authoritative preview)" as LocalBuild <<Execution>>
  component "Publish Candidate\n(source + metadata refs)" as PublishCandidate <<Execution>>
  component "Ownership Mapping Proof\n(logged-in GitHub + Steam sessions)" as OwnershipMapProof <<Execution>>
}

package "Canonical CI Domain" #1f2b36 {
  component "Official Toolchain Image\n(hash-locked to SDK bundle)" as CIImage <<Guard>>
  component "Deterministic Multi-Target Build" as CIBuild <<Execution>>
  component "CI Provenance Authority\n(workflow identity + attestations)" as CIProv <<Authority>>
  component "Provenance + Reproducibility Gate" as CIGate <<Guard>>
}

package "Distribution Outputs" #2d2637 {
  component "Canonical Runtime Artifacts" as CanonicalArtifacts <<Artifact>>
  component "Canonical Build Metadata\n(hashes + provenance)" as CanonicalMetadata <<Artifact>>
}

RootDev -[#7ecbff]-> ToolchainManifest : pin canonical toolchain
RootDev -[#7ecbff]-> SDKSource : own platform source
ToolchainManifest -[#7ecbff]-> BundleBuilder : lock build inputs
SDKSource -[#7ecbff]-> BundleBuilder : lock build inputs

BundleBuilder -[#9de37e]-> VendoredToolchain : bundle
BundleBuilder -[#9de37e]-> ContractTemplates : bundle
BundleBuilder -[#9de37e]-> ModTemplates : bundle
BundleBuilder -[#9de37e]-> LocalValidator : bundle
BundleBuilder -[#9de37e]-> ProvenanceCLI : bundle
BundleBuilder -[#9de37e]-> OwnershipMapCLI : bundle

ModDev -[#7ecbff]-> LocalBuild : author and iterate
VendoredToolchain -[#9de37e]-> LocalBuild : local parity preview
ContractTemplates -[#9de37e]-> LocalBuild : compile contract targets
ModTemplates -[#9de37e]-> LocalBuild : scaffold mod crate
LocalValidator -[#9de37e]-> LocalBuild : preflight DAG checks
ProvenanceCLI -[#9de37e]-> LocalBuild : optional provenance preview
OwnershipMapCLI -[#9de37e]-> OwnershipMapProof : collect ownership mapping proof
OwnershipMapProof -[#7ecbff]-> PublishCandidate : attach ownership mapping proof
LocalBuild -[#7ecbff]-> PublishCandidate : package candidate

VendoredToolchain -[#f5c57a]-> CIImage : hash parity requirement
PublishCandidate -[#7ecbff]-> CIBuild : submit source + metadata
CIImage -[#9de37e]-> CIBuild : canonical compiler/runtime
CIBuild -[#9de37e]-> CIGate : build outputs
CIProv -[#f5c57a]-> CIGate : authoritative CI provenance
ProvenanceCLI -[#9de37e]-> CIGate : shared provenance format only
CIGate -[#f5c57a]-> CanonicalArtifacts : trusted artifacts
CIGate -[#f5c57a]-> CanonicalMetadata : trusted metadata

LocalBuild -[dashed,#c87878]-> CanonicalArtifacts : local artifacts not authoritative

ToolchainManifest -[hidden]- SDKSource
VendoredToolchain -[hidden]- ContractTemplates
ModTemplates -[hidden]- LocalValidator
CIImage -[hidden]- CIBuild
CIProv -[hidden]- CIGate
CanonicalArtifacts -[hidden]- CanonicalMetadata

note right of CIGate
Authority rule:
- Only CI-built canonical artifacts are authoritative
- CI provenance authority is isolated from developer workspace
- No custom owner-signature mechanism in v1
- Local builds are developer feedback only
- rustc/cargo/target hashes must match SDK bundle
- Deterministic target matrix is mandatory
end note

@enduml
