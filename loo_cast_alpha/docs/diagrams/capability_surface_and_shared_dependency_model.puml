@startuml
title Capability Surface & Shared Dependency Model (Contract-Gated Bevy Access)
left to right direction

' =========================
' DARK MODE REVIEW THEME
' =========================

skinparam backgroundColor #121417
skinparam shadowing false
skinparam defaultFontName JetBrains Mono
skinparam defaultFontColor #f3f5f7
skinparam linetype polyline
skinparam componentStyle rectangle
skinparam nodesep 70
skinparam ranksep 90

skinparam component {
  BackgroundColor #26313c
  BorderColor #7c8b9b
  FontColor #ffffff
  RoundCorner 10
  BackgroundColor<<Public>> #234057
  BorderColor<<Public>> #77b7e8
  BackgroundColor<<Private>> #2f3f2a
  BorderColor<<Private>> #96c37a
  BackgroundColor<<External>> #3a2f44
  BorderColor<<External>> #b492d8
  BackgroundColor<<Guard>> #3a3528
  BorderColor<<Guard>> #d6c57f
}

skinparam package {
  BackgroundColor #1b2128
  BorderColor #5f6a75
  FontColor #ffffff
}

skinparam note {
  BackgroundColor #2a3138
  BorderColor #8b98a6
  FontColor #f3f5f7
}

skinparam ArrowColor #79b8ff
skinparam ArrowFontColor #f3f5f7

package "Upstream Dependency" #2c2438 {
  component "bevy crate" as BevyCrate <<External>>
}

package "Platform Capability Contracts (Public Surface)" #1f2b36 {
  component "bevy_contract\n(capability envelope)" as BevyContract <<Public>>
  component "core_mod_contract\n(runtime contract root)" as CoreContract <<Public>>
  component "third_party_mod_contracts" as ModContracts <<Public>>
}

package "Third-Party Mod Crates" #2d2637 {
  component "mod_a crate" as ModA <<Public>>
  component "mod_b crate" as ModB <<Public>>
}

package "Runtime Implementation (Private Surface)" #24372d {
  component "core_mod runtime crate" as CoreRuntime <<Private>>
  component "Bevy Runtime Instance\n(single process owner)" as BevyRuntime <<Private>>
}

BevyCrate -[#b492d8]-> BevyContract : wrapped and curated
BevyContract -[#7ecbff]-> CoreContract : promoted platform capability
CoreContract -[#7ecbff]-> ModContracts : shared downstream contract root

ModA -[#7ecbff]-> ModContracts : compile-time dependency
ModB -[#7ecbff]-> ModContracts : compile-time dependency

CoreContract -[#9de37e]-> CoreRuntime : implemented by runtime root
ModA -[#9de37e]-> CoreRuntime : runtime binds through contract
ModB -[#9de37e]-> CoreRuntime : runtime binds through contract
CoreRuntime -[#9de37e]-> BevyRuntime : owns live Bevy integration

BevyCrate -[dashed,#c87878]-> ModA : raw Bevy dependency forbidden
BevyCrate -[dashed,#c87878]-> ModB : raw Bevy dependency forbidden

ModA -[hidden]- ModB
BevyContract -[hidden]- CoreContract
CoreContract -[hidden]- ModContracts

note right of BevyContract
Contract surface policy:
- Bevy is exposed only through bevy_contract
- Platform semantics are enforced at contract layer
- Third-party mods depend on contracts, not raw Bevy
- Private runtime crates remain implementation detail
end note

@enduml
