@startuml
title Event Contract & Channel Topology Model (Capability-Scoped Decoupling)
left to right direction

' =========================
' DARK MODE REVIEW THEME
' =========================

skinparam backgroundColor #121417
skinparam shadowing false
skinparam defaultFontName JetBrains Mono
skinparam defaultFontColor #f3f5f7
skinparam linetype polyline
skinparam componentStyle rectangle
skinparam nodesep 70
skinparam ranksep 90

skinparam component {
  BackgroundColor #26313c
  BorderColor #7c8b9b
  FontColor #ffffff
  RoundCorner 10
  BackgroundColor<<Contract>> #234057
  BorderColor<<Contract>> #77b7e8
  BackgroundColor<<Runtime>> #2f3f2a
  BorderColor<<Runtime>> #96c37a
  BackgroundColor<<Mod>> #3a2f44
  BorderColor<<Mod>> #b492d8
  BackgroundColor<<Guard>> #3a3528
  BorderColor<<Guard>> #d6c57f
}

skinparam package {
  BackgroundColor #1b2128
  BorderColor #5f6a75
  FontColor #ffffff
}

skinparam note {
  BackgroundColor #2a3138
  BorderColor #8b98a6
  FontColor #f3f5f7
}

skinparam ArrowColor #79b8ff
skinparam ArrowFontColor #f3f5f7

package "Contract Layer (Compile-Time)" #1f2b36 {
  component "capability_event_contract" as EventContract <<Contract>>
  component "Event Type Catalog\n(payload structs/enums)" as EventTypes <<Contract>>
  component "Channel Declarations\n(name + mode + ordering + ownership policy)" as ChannelDecl <<Contract>>
}

package "Admission + Runtime Lock" #24372d {
  component "Capability Registry" as CapRegistry <<Runtime>>
  component "Channel Topology Builder" as TopologyBuilder <<Guard>>
  component "Locked Channel Topology\n(immutable after lock)" as LockedTopology <<Runtime>>
}

package "Provider Mods / Capabilities" #2d2637 {
  component "Provider Mod A\n(sim capability)" as ProviderA <<Mod>>
  component "Provider Mod B\n(economy capability)" as ProviderB <<Mod>>
}

package "Consumer Mods / Capabilities" #2d2637 {
  component "Consumer Mod X\n(render capability)" as ConsumerX <<Mod>>
  component "Consumer Mod Y\n(audio/ui capability)" as ConsumerY <<Mod>>
}

package "Dispatch Runtime" #24372d {
  component "Event Router" as Router <<Runtime>>
  component "Delivery Scheduler\n(deterministic subscriber order)" as Scheduler <<Guard>>
  component "Channel Buffers" as Buffers <<Runtime>>
}

EventContract -[#7ecbff]-> EventTypes : defines payload schema
EventContract -[#7ecbff]-> ChannelDecl : defines channel semantics

ProviderA -[#7ecbff]-> EventContract : compile-time dependency
ProviderB -[#7ecbff]-> EventContract : compile-time dependency
ConsumerX -[#7ecbff]-> EventContract : compile-time dependency
ConsumerY -[#7ecbff]-> EventContract : compile-time dependency

CapRegistry -[#9de37e]-> TopologyBuilder : provider/consumer declarations
ChannelDecl -[#9de37e]-> TopologyBuilder : channel contract metadata
TopologyBuilder -[#9de37e]-> LockedTopology : enforce invariants + freeze graph

LockedTopology -[#9de37e]-> Router : routing table
Scheduler -[#f5c57a]-> Router : stable delivery order
Router -[#9de37e]-> Buffers : enqueue/dequeue by channel mode

ProviderA -[#9de37e]-> Router : publish events
ProviderB -[#9de37e]-> Router : publish events
Router -[#9de37e]-> ConsumerX : deliver subscribed events
Router -[#9de37e]-> ConsumerY : deliver subscribed events

ProviderA -[dashed,#c87878]-> ConsumerX : direct cross-mod callback forbidden
ProviderB -[dashed,#c87878]-> ConsumerY : shared mutable state coupling forbidden

note right of ChannelDecl
Channel mode examples:
- Broadcast stream
- Directed request/response
- Queued command stream
end note

note bottom of TopologyBuilder
Admission/runtime invariants:
- Ownership mapping controls who may publish owned channels
- Exclusive-owner channel ambiguity is a hard fail
- Channel graph is immutable after runtime lock
end note

note right of Scheduler
Ordering rule:
delivery order is deterministic and derived
from locked runtime load ordering.
end note

@enduml
