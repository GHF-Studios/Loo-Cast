@startuml
title ABI Boundary & HostContext Layering (Single Unsafe Entry)
left to right direction

' =========================
' DARK MODE REVIEW THEME
' =========================

skinparam backgroundColor #121417
skinparam shadowing false
skinparam defaultFontName JetBrains Mono
skinparam defaultFontColor #f3f5f7
skinparam linetype polyline
skinparam componentStyle rectangle
skinparam nodesep 70
skinparam ranksep 90

skinparam component {
  BackgroundColor #26313c
  BorderColor #7c8b9b
  FontColor #ffffff
  RoundCorner 10
  BackgroundColor<<Runtime>> #2f3f2a
  BorderColor<<Runtime>> #96c37a
  BackgroundColor<<API>> #234057
  BorderColor<<API>> #77b7e8
  BackgroundColor<<Guard>> #3a3528
  BorderColor<<Guard>> #d6c57f
  BackgroundColor<<Unsafe>> #4a2c2f
  BorderColor<<Unsafe>> #d4959c
}

skinparam package {
  BackgroundColor #1b2128
  BorderColor #5f6a75
  FontColor #ffffff
}

skinparam note {
  BackgroundColor #2a3138
  BorderColor #8b98a6
  FontColor #f3f5f7
}

skinparam ArrowColor #79b8ff
skinparam ArrowFontColor #f3f5f7

package "Engine Host Domain" #1f2b36 {
  component "Loader / Orchestrator" as Loader <<Runtime>>
  component "ABI Dispatch" as Dispatch <<Guard>>
}

package "FFI Boundary (Only C ABI Surface)" #3a2528 {
  component "extern \"C\" fn mod_entry(ctx: *mut HostContext)" as ModEntry <<Unsafe>>
}

package "HostContext Bridge" #24372d {
  component "Opaque HostContext Pointer" as OpaqueCtx <<Guard>>
  component "Unsafe Dereference +\nInvariant Checks" as UnsafeBridge <<Unsafe>>
  component "Safe HostContext Wrapper" as SafeWrapper <<API>>
}

package "Rust Modding Framework API" #2c2438 {
  component "Capability Access API" as CapabilityAPI <<API>>
  component "System + Resource Registration" as Registration <<API>>
  component "Runtime Hooks\n(startup / fixed update / shutdown)" as Hooks <<Runtime>>
}

package "core_mod Runtime Root" #24372d {
  component "Bevy Runtime" as BevyRuntime <<Runtime>>
  component "ECS World" as ECSWorld <<Runtime>>
}

Loader -[#f5c57a]-> Dispatch : load mod and invoke entry
Dispatch -[#c87878]-> ModEntry : call exported symbol
ModEntry -[#c87878]-> OpaqueCtx : receive ctx pointer
OpaqueCtx -[#c87878]-> UnsafeBridge : raw pointer access
UnsafeBridge -[#9de37e]-> SafeWrapper : checked conversion
SafeWrapper -[#7ecbff]-> CapabilityAPI : expose safe host handles
CapabilityAPI -[#7ecbff]-> Registration : register systems/resources
Registration -[#9de37e]-> Hooks : install lifecycle hooks
Hooks -[#9de37e]-> BevyRuntime : schedule integration
BevyRuntime -[#9de37e]-> ECSWorld : drive world execution

note right of ModEntry
Single FFI boundary for mod entry.
Everything below this layer stays in Rust APIs.
end note

note bottom of UnsafeBridge
Unsafe code is confined to the HostContext bridge.
No raw pointer operations leak into mod-facing APIs.
end note

@enduml
