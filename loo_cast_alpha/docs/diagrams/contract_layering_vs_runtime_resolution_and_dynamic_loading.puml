@startuml
title Contract Layering vs Selection Resolution vs Dynamic Loading (Separated Domains)

' =========================
' DARK MODE REVIEW THEME
' =========================

skinparam backgroundColor #121417
skinparam shadowing false
skinparam defaultFontName JetBrains Mono
skinparam defaultFontColor #f3f5f7
skinparam linetype ortho
skinparam nodesep 70
skinparam ranksep 90

skinparam activity {
  StartColor #79b8ff
  EndColor #79b8ff
  BackgroundColor #26313c
  BorderColor #7c8b9b
  FontColor #ffffff
  DiamondBackgroundColor #2f3a45
  DiamondBorderColor #8fa0b2
  DiamondFontColor #ffffff
  ArrowColor #79b8ff
  ArrowFontColor #f3f5f7
  BarColor #627181
}

skinparam partition {
  BackgroundColor #1b2128
  BorderColor #5f6a75
  FontColor #ffffff
}

skinparam note {
  BackgroundColor #2a3138
  BorderColor #8b98a6
  FontColor #f3f5f7
}

start

partition "A) Contract Definition Layer (Schema/ABI Space)" #1f2b36 {
  :Collect contract crates\n(core_engine_contract,\ncore_mod_contract,\nthird-party contract crates);
  :Validate contract dependency DAG\n(schema-level, no runtime instances);
  :Emit contract compatibility surface\n(versioned ABI/schema metadata);
}

partition "B) Release Selection Layer (Registry Public Set)" #24372d {
  :Collect requested root versions;
  :Fetch immutable version records\n+ mutable status flags;
  if (Any selected version pending/deprecated/banned?) then (yes)
    :Reject selection before runtime;
    stop
  else (no)
    :Resolve transitive closure\nfrom exact version records;
    :Enforce single version per\n(namespace, mod_name);
    if (Conflict found?) then (yes)
      :Reject selection before runtime;
      stop
    else (no)
      :Topological sort\n(validated DAG);
      :Emit deterministic load plan;
    endif
  endif
}

partition "C) Runtime Load Layer (Engine Host)" #2d2637 {
  :Load core_mod.dll first;
  :Load remaining mods\nin deterministic topological order;
  :Register ABI + systems/resources;
  :Freeze runtime graph lock;
}

stop

note right
Separation rule:
- Layer A defines compatibility contracts only
- Layer B selects concrete release instances
- Layer C performs dynamic loading of selected instances
end note

@enduml
