@startuml
!pragma teoz true
!pragma sequenceMessageSpan true
title Engine Boot & Load Sequence (Guarded Runtime Initialization)
hide footbox
autonumber "<color:#8fb6ff><b>[000]</b></color> "
skinparam maxMessageSize 44
skinparam ParticipantPadding 24
skinparam BoxPadding 12
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

' =========================
' DARK MODE REVIEW THEME
' =========================

skinparam backgroundColor #121417
skinparam shadowing false
skinparam defaultFontName JetBrains Mono
skinparam defaultFontColor #f3f5f7

skinparam sequence {
  ArrowColor #79b8ff
  ArrowFontColor #f3f5f7

  LifeLineBorderColor #6d7986
  LifeLineBackgroundColor #1f262d

  ParticipantBorderColor #738396
  ParticipantBackgroundColor #25303a
  ParticipantFontColor #ffffff

  ActorBorderColor #98a7b8
  ActorBackgroundColor #2b3742
  ActorFontColor #ffffff

  GroupBorderColor #5f6a75
  GroupBackgroundColor #1a2128
  GroupFontColor #ffffff

  DividerBorderColor #5f6a75
  DividerBackgroundColor #1f262d
  DividerFontColor #ffffff
}

skinparam note {
  BackgroundColor #2a3138
  BorderColor #8b98a6
  FontColor #f3f5f7
}

box "Host Process Boundary" #22352b
control "Launcher" as L
control "Engine Orchestrator" as E
control "Validation Gate" as V
control "Load Scheduler" as S
control "Runtime Initializer" as I
end box

== Boot Entry ==

L -> E: Start with\nvalidated mod set
activate E

== Validation Phase ==

E -> V: Verify platform\nversion
V --> E: version check\nstatus
E -> V: Verify content hashes
V --> E: hash check\nstatus
E -> V: Verify ownership mapping
V --> E: ownership mapping check\nstatus
E -> V: Validate dependency\nDAG
V --> E: DAG check\nstatus

alt Any validation check fails
  E --> L: Abort boot
  deactivate E
else All validation checks pass

  == Load Phase ==
  E -> S: Load core_mod
  activate S
  S -> S: Load core_mod
  E -> S: Load other mods\n(topological order)
  S -> S: Load ordered mod set
  S --> E: Load phase\ncompleted
  deactivate S

  == Initialization Phase ==
  E -> I: ABI registration
  activate I
  I -> I: Register ABI surfaces
  E -> I: System/component\nregistration
  I -> I: Register systems and components
  E -> I: Runtime lock
  I -> I: Freeze runtime graph
  I --> E: Runtime initialized
  deactivate I

  E --> L: Boot completed
  deactivate E
end

note across
No runtime loading or unloading after lock.
Determinism comes from successful validation gates + fixed topological load order.
end note

@enduml
