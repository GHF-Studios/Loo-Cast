@startuml
title Dynamic Linking & Symbol Universe Model (Single Bevy Runtime Domain)
left to right direction

' =========================
' DARK MODE REVIEW THEME
' =========================

skinparam backgroundColor #121417
skinparam shadowing false
skinparam defaultFontName JetBrains Mono
skinparam defaultFontColor #f3f5f7
skinparam linetype polyline
skinparam componentStyle rectangle
skinparam nodesep 70
skinparam ranksep 90

skinparam component {
  BackgroundColor #26313c
  BorderColor #7c8b9b
  FontColor #ffffff
  RoundCorner 10
  BackgroundColor<<Runtime>> #2f3f2a
  BorderColor<<Runtime>> #96c37a
  BackgroundColor<<Guard>> #3a3528
  BorderColor<<Guard>> #d6c57f
}

skinparam package {
  BackgroundColor #1b2128
  BorderColor #5f6a75
  FontColor #ffffff
}

skinparam note {
  BackgroundColor #2a3138
  BorderColor #8b98a6
  FontColor #f3f5f7
}

skinparam ArrowColor #79b8ff
skinparam ArrowFontColor #f3f5f7

package "Host Process" #1f2b36 {
  component "engine_binary" as Engine <<Runtime>>
  component "Dynamic Loader" as Loader <<Guard>>
  component "Global Symbol Table" as Symbols <<Guard>>
}

package "Runtime Root DLL" #24372d {
  component "core_mod.dll" as CoreDLL <<Runtime>>
  component "Framework Root Exports" as RootExports <<Guard>>
  component "Bevy Runtime\n(single instance)" as BevyRuntime <<Runtime>>
}

package "Dynamic Mod DLL Boundary" #2d2637 {
  component "mod_a.dll" as ModA <<Runtime>>
  component "mod_b.dll" as ModB <<Runtime>>
}

Engine -[#7ecbff]-> Loader : boot runtime
Loader -[#f5c57a]-> CoreDLL : load first
CoreDLL -[#9de37e]-> BevyRuntime : instantiate once
CoreDLL -[#9de37e]-> RootExports : publish framework ABI
RootExports -[#9de37e]-> Symbols : register shared symbols

Loader -[#f5c57a]-> ModA : load after core_mod.dll
Loader -[#f5c57a]-> ModB : load after core_mod.dll

ModA -[#9de37e]-> RootExports : bind framework entry points
ModB -[#9de37e]-> RootExports : bind framework entry points
ModA -[#9de37e]-> Symbols : resolve imported symbols
ModB -[#9de37e]-> Symbols : resolve imported symbols

ModA -[dashed,#c87878]-> BevyRuntime : no private Bevy ownership
ModB -[dashed,#c87878]-> BevyRuntime : no private Bevy ownership

ModA -[hidden]- ModB
CoreDLL -[hidden]- RootExports
RootExports -[hidden]- BevyRuntime

note right of CoreDLL
Linking guarantees:
- One Bevy runtime in process
- Mods share one symbol universe
- No per-crate Bevy DLL splitting
- Dynamic boundary exists at mod DLL level only
end note

@enduml
