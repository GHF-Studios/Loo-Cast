@startuml

' ============================================
' DARK MODE SAFE GLOBAL THEME
' ============================================

skinparam backgroundColor #161616
skinparam shadowing false
skinparam defaultFontName JetBrains Mono
skinparam defaultFontColor #f5f5f5

skinparam rectangle {
    BackgroundColor #262626
    BorderColor #8f8f8f
    FontColor #ffffff
    RoundCorner 12
}

skinparam node {
    BackgroundColor #2b2b2b
    BorderColor #999999
    FontColor #ffffff
    RoundCorner 10
}

skinparam database {
    BackgroundColor #303030
    BorderColor #aaaaaa
    FontColor #ffffff
}

skinparam cloud {
    BackgroundColor #2b2b2b
    BorderColor #aaaaaa
    FontColor #ffffff
}

skinparam queue {
    BackgroundColor #2d2d2d
    BorderColor #aaaaaa
    FontColor #ffffff
}

skinparam ArrowColor #6cb6ff
skinparam ArrowFontColor #ffffff

skinparam package {
    BackgroundColor #202020
    BorderColor #666666
    FontColor #ffffff
}

title Distributed Cyberpunk MMO Infrastructure

' ============================================
' USERS
' ============================================

actor "Players" as Players
actor "Moderators" as Mods
actor "Developers" as Devs

cloud "Internet" as Internet

Players --> Internet
Mods --> Internet
Devs --> Internet

' ============================================
' EDGE NETWORK
' ============================================

package "Global Edge Layer" {

    node "Global CDN" as CDN
    node "DDoS Shield" as Shield
    node "Edge API Gateway" as Gateway
    queue "Realtime Relay Mesh" as Relay

    Internet --> Shield
    Shield --> CDN
    CDN --> Gateway
    Gateway --> Relay
}

' ============================================
' AUTH REGION
' ============================================

package "Identity & Security" {

    rectangle "Authentication Cluster" {

        node "OAuth Service" as OAuth
        node "Session Service" as Session
        node "MFA Service" as MFA
        database "Identity DB" as IdentityDB

        OAuth --> Session
        OAuth --> MFA
        OAuth --> IdentityDB
    }

    rectangle "Security Layer" {

        node "Anti-Cheat Engine" as AntiCheat
        node "Behavior Analysis AI" as BehaviorAI
        queue "Ban Event Stream" as BanStream

        AntiCheat --> BehaviorAI
        BehaviorAI --> BanStream
    }
}

Gateway --> OAuth
Gateway --> AntiCheat

' ============================================
' GAME REGIONS
' ============================================

package "NA-East Region" {

    node "Zone Controller" as NAZone
    node "Matchmaking Service" as NAMatch
    node "Inventory Service" as NAInventory
    node "Guild Service" as NAGuild

    database "Player State DB" as NAPlayerDB
    database "World State DB" as NAWorldDB

    queue "Combat Event Bus" as NACombatBus

    NAMatch --> NAZone
    NAZone --> NACombatBus
    NAZone --> NAPlayerDB
    NAZone --> NAWorldDB
    NAGuild --> NAPlayerDB
    NAInventory --> NAPlayerDB
}

package "EU-West Region" {

    node "Zone Controller" as EUZone
    node "Matchmaking Service" as EUMatch
    node "Inventory Service" as EUInventory
    node "Guild Service" as EUGuild

    database "Player State DB" as EUPlayerDB
    database "World State DB" as EUWorldDB

    queue "Combat Event Bus" as EUCombatBus

    EUMatch --> EUZone
    EUZone --> EUCombatBus
    EUZone --> EUPlayerDB
    EUZone --> EUWorldDB
    EUGuild --> EUPlayerDB
    EUInventory --> EUPlayerDB
}

Relay --> NAZone
Relay --> EUZone

' ============================================
' ECONOMY PLATFORM
' ============================================

package "Economy Platform" {

    node "Marketplace API" as Market
    node "Trade Validator" as TradeValidator
    node "Fraud Detection AI" as FraudAI
    database "Transaction Ledger" as Ledger

    queue "Economy Stream" as EconomyBus

    Market --> TradeValidator
    TradeValidator --> FraudAI
    TradeValidator --> Ledger
    Market --> EconomyBus
}

NAInventory --> Market
EUInventory --> Market

' ============================================
' LIVE OPERATIONS
' ============================================

package "Live Operations" {

    node "Patch Deployment Service" as Deploy
    node "Feature Flag Service" as Flags
    node "Live Event Orchestrator" as Events
    node "Notification Service" as Notify

    queue "Global Event Stream" as GlobalBus

    Deploy --> Flags
    Events --> GlobalBus
    Notify --> GlobalBus
}

Devs --> Deploy
Mods --> Events

' ============================================
' ANALYTICS & OBSERVABILITY
' ============================================

package "Observability Stack" {

    node "Metrics Aggregator" as Metrics
    node "Distributed Tracing" as Tracing
    node "Log Processing Cluster" as Logs
    node "Anomaly Detection AI" as Anomaly

    database "Telemetry Warehouse" as Warehouse

    Metrics --> Warehouse
    Tracing --> Warehouse
    Logs --> Warehouse
    Warehouse --> Anomaly
}

NAZone --> Metrics
EUZone --> Metrics

NACombatBus --> Logs
EUCombatBus --> Logs

Gateway --> Tracing
OAuth --> Tracing

' ============================================
' BACKGROUND PROCESSING
' ============================================

package "Background Workers" {

    node "Quest Simulation Engine" as QuestSim
    node "NPC AI Cluster" as NPCAI
    node "World Persistence Worker" as Persist
    node "Backup Coordinator" as Backup

    queue "World Event Stream" as WorldBus

    QuestSim --> WorldBus
    NPCAI --> WorldBus
    Persist --> WorldBus

    Persist --> NAWorldDB
    Persist --> EUWorldDB

    Backup --> NAPlayerDB
    Backup --> EUPlayerDB
}

' ============================================
' CROSS REGION SYNC
' ============================================

NAPlayerDB <--> EUPlayerDB : Account Sync
NAWorldDB <--> EUWorldDB : World Replication

GlobalBus --> NAZone
GlobalBus --> EUZone

EconomyBus --> FraudAI
BanStream --> Session

@enduml