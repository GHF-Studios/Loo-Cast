@startuml

' =========================
' DARK MODE SAFE THEME
' =========================

skinparam backgroundColor #1a1a1a
skinparam shadowing false
skinparam defaultFontName JetBrains Mono
skinparam defaultFontColor #f5f5f5

skinparam sequence {
    ArrowColor #5fb3ff
    ArrowFontColor #ffffff

    LifeLineBorderColor #909090
    LifeLineBackgroundColor #262626

    ParticipantBorderColor #8d8d8d
    ParticipantBackgroundColor #2c2c2c
    ParticipantFontColor #ffffff

    ActorBorderColor #b0b0b0
    ActorBackgroundColor #303030
    ActorFontColor #ffffff

    GroupBorderColor #777777
    GroupBackgroundColor #242424
    GroupFontColor #ffffff

    DividerBackgroundColor #303030
    DividerBorderColor #777777
    DividerFontColor #ffffff
}

skinparam database {
    BackgroundColor #2d2d2d
    BorderColor #aaaaaa
    FontColor #ffffff
}

skinparam queue {
    BackgroundColor #2d2d2d
    BorderColor #aaaaaa
    FontColor #ffffff
}

skinparam note {
    BackgroundColor #353535
    BorderColor #999999
    FontColor #ffffff
}

title Steam Workshop Modding Ecosystem

actor Player
actor ModCreator as Creator

participant "Game Client" as Game
participant "Steam Client" as Steam
participant "Steam Auth API" as SteamAuth
participant "Community Backend" as Backend
participant "Mod Registry Service" as Registry
participant "Dependency Resolver" as Resolver
participant "Workshop Sync Service" as Workshop
participant "CDN Edge Cache" as CDN
participant "Local Mod Loader" as Loader
participant "Sandbox Runtime" as Sandbox
participant "Telemetry Pipeline" as Telemetry
participant "Moderation AI" as ModAI
participant "Policy Engine" as Policy
database "Metadata DB" as MetaDB
database "Distributed Object Store" as ObjectStore
queue "Event Stream" as EventBus
participant "Build Worker Cluster" as Workers
participant "Version Diff Engine" as Diff
participant "Server Browser" as Browser
participant "Dedicated Server" as Server

== Initial Launch ==

Player -> Game : Launch game
Game -> Steam : Verify ownership
Steam --> Game : Ownership valid

Game -> SteamAuth : Request OpenID token
SteamAuth --> Game : Steam identity token

Game -> Backend : Authenticate via Steam
Backend -> SteamAuth : Validate token

alt Valid Steam user
    SteamAuth --> Backend : User verified
    Backend --> Game : Session JWT + entitlements
else Invalid token
    SteamAuth --> Backend : Invalid session
    Backend --> Game : Authentication failed
    Game --> Player : Exit to login screen
end

== Ecosystem Bootstrap ==

Game -> Backend : Request mod ecosystem config
Backend -> Policy : Evaluate distribution rules

note right of Policy
- No paid mods
- CDN-only delivery
- Peer-assisted mirroring
- Open dependency policy
- Creator attribution enforced
end note

Policy --> Backend : Policy approved
Backend --> Game : Registry endpoints + policies

== Creator Upload Workflow ==

Creator -> Game : Open Mod SDK
Game -> Loader : Package mod bundle

Loader -> Workers : Submit build package
Workers -> Workers : Compile shaders
Workers -> Workers : Validate manifests
Workers -> Workers : Run compatibility checks

par Security scan
    Workers -> ModAI : Analyze scripts/assets
    ModAI --> Workers : Risk score LOW
else Dependency indexing
    Workers -> Resolver : Scan dependencies
    Resolver --> Workers : Dependency graph
else Binary optimization
    Workers -> Diff : Generate binary delta patches
    Diff --> Workers : Delta package ready
end

Workers -> ObjectStore : Upload mod artifacts
Workers -> MetaDB : Store metadata

Workers -> Workshop : Publish Workshop item

alt Workshop publish success
    Workshop --> Workers : Published item ID
else Workshop API rate limit
    Workshop --> Workers : Retry-After header
    Workers -> Workers : Queue retry job
end

Workers -> EventBus : Emit ModPublished event

== Automated Distribution ==

par CDN propagation
    EventBus -> CDN : Cache mod package
    CDN -> CDN : Geo replication
else Registry sync
    EventBus -> Registry : Register version
    Registry -> MetaDB : Update index
else Community feed
    EventBus -> Backend : Create activity entry
end

== Player Browsing Mods ==

Player -> Game : Open mod browser
Game -> Browser : Request server-compatible mods

Browser -> Registry : Fetch curated list
Registry --> Browser : Compatible mods

Browser -> Server : Query installed modpack
Server --> Browser : Required mods + versions

Browser --> Game : Recommended sync plan

== Dependency Resolution ==

Game -> Resolver : Resolve dependencies

loop Until graph resolved
    Resolver -> Registry : Query dependency metadata
    Registry --> Resolver : Child dependencies

    alt Circular dependency detected
        Resolver --> Game : Dependency conflict
        break
    else Dependency valid
        Resolver -> Resolver : Expand graph
    end
end

Resolver --> Game : Final install manifest

== Intelligent Download Pipeline ==

par Download from CDN
    Game -> CDN : Request compressed package
    CDN --> Game : Stream chunks
else Peer-assisted delivery
    Game -> Game : Discover community peers
    Game -> Game : Fetch missing chunks
else Delta patching
    Game -> Diff : Request differential update
    Diff --> Game : Binary patch
end

Game -> Loader : Install mods
Loader -> Sandbox : Validate execution permissions

alt Unsafe native code detected
    Sandbox --> Loader : Restricted execution
    Loader --> Game : Warning displayed
else Safe execution
    Sandbox --> Loader : Approved
end

== Multiplayer Join ==

Player -> Game : Join modded server
Game -> Server : Send mod hashes

Server -> Server : Validate client integrity

alt Client missing mods
    Server --> Game : Missing dependency list
    Game -> Registry : Auto-subscribe required mods
else Hash mismatch
    Server --> Game : Reject connection
else Validation successful
    Server --> Game : Connection approved
end

== Runtime Telemetry ==

loop Every gameplay session
    Sandbox -> Telemetry : Send crash metrics
    Sandbox -> Telemetry : Send performance stats
    Sandbox -> Telemetry : Send script violations
end

Telemetry -> ModAI : Aggregate anomaly detection

alt Malicious behavior detected
    ModAI -> Policy : Request quarantine
    Policy --> Registry : Flag mod version
    Registry -> Workshop : Hide listing
    Registry -> CDN : Purge cached binaries
else Healthy ecosystem
    ModAI --> Telemetry : No action required
end

== Live Hot Reload ==

Creator -> Workshop : Push hotfix update
Workshop -> EventBus : ModUpdated event

EventBus -> Registry : Refresh version index
Registry -> Game : Notify subscribed players

alt Player in active session
    Game -> Loader : Perform hot reload
    Loader -> Sandbox : Swap runtime assets

    alt Hot reload compatible
        Sandbox --> Loader : Reload successful
        Loader --> Game : Assets updated live
    else Breaking API changes
        Sandbox --> Loader : Restart required
        Loader --> Game : Queue update for reboot
    end

else Player offline
    Registry -> CDN : Pre-cache update
end

== Shutdown ==

Player -> Game : Exit game
Game -> Backend : Flush telemetry
Backend --> Game : Session finalized

Game -> Steam : Close session
Steam --> Game : Session ended

@enduml