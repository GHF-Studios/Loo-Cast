@startuml

' =========================
' DARK MODE SAFE THEME
' =========================

skinparam backgroundColor #1e1e1e
skinparam shadowing false
skinparam defaultFontName JetBrains Mono
skinparam defaultFontColor #f5f5f5

skinparam sequence {
    ArrowColor #6CB6FF
    ArrowFontColor #ffffff

    LifeLineBorderColor #8a8a8a
    LifeLineBackgroundColor #2b2b2b

    ParticipantBorderColor #8a8a8a
    ParticipantBackgroundColor #2b2b2b
    ParticipantFontColor #ffffff

    ActorBorderColor #aaaaaa
    ActorBackgroundColor #333333
    ActorFontColor #ffffff

    GroupBorderColor #777777
    GroupBackgroundColor #252525
    GroupFontColor #ffffff

    DividerBackgroundColor #333333
    DividerBorderColor #777777
    DividerFontColor #ffffff
}

skinparam database {
    BackgroundColor #2b2b2b
    BorderColor #999999
    FontColor #ffffff
}

skinparam queue {
    BackgroundColor #2b2b2b
    BorderColor #999999
    FontColor #ffffff
}

skinparam note {
    BackgroundColor #383838
    BorderColor #888888
    FontColor #ffffff
}

title Complex E-Commerce Checkout Flow

actor Customer
participant "Web Frontend" as Web
participant "API Gateway" as API
participant "Auth Service" as Auth
participant "Cart Service" as Cart
participant "Inventory Service" as Inventory
participant "Pricing Service" as Pricing
participant "Payment Service" as Payment
participant "Fraud Detection" as Fraud
participant "Order Service" as Order
database "Order DB" as DB
queue "Event Bus" as Bus
participant "Notification Service" as Notify
participant "Shipping Service" as Shipping
participant "Analytics Service" as Analytics
participant "Recommendation Engine" as Rec

== User Authentication ==

Customer -> Web : Login(email,password)
Web -> API : POST /login
API -> Auth : Validate credentials

alt Valid credentials
    Auth --> API : JWT Token
    API --> Web : 200 OK + Token
    Web --> Customer : Login successful
else Invalid credentials
    Auth --> API : Authentication failed
    API --> Web : 401 Unauthorized
    Web --> Customer : Show error message
end

== Add Items to Cart ==

Customer -> Web : Add item to cart
Web -> API : POST /cart/items
API -> Cart : Add product

par Inventory check
    Cart -> Inventory : Validate stock
    Inventory --> Cart : Stock available
else Pricing lookup
    Cart -> Pricing : Fetch latest pricing
    Pricing --> Cart : Price details
end

Cart --> API : Cart updated
API --> Web : Updated cart response

== Checkout Process ==

Customer -> Web : Proceed to checkout
Web -> API : POST /checkout

API -> Auth : Validate JWT
Auth --> API : Token valid

API -> Cart : Get cart contents
Cart --> API : Cart items

API -> Pricing : Recalculate totals
Pricing --> API : Final amount

API -> Fraud : Pre-check customer risk

alt High risk detected
    Fraud --> API : Risk score HIGH
    API --> Web : Transaction blocked
    Web --> Customer : Contact support
else Risk acceptable
    Fraud --> API : Risk score OK
end

== Payment Authorization ==

API -> Payment : Authorize payment

loop Retry up to 3 times
    Payment -> Fraud : Validate payment pattern
    Fraud --> Payment : Validation OK

    alt Payment provider timeout
        Payment -> Payment : Retry request
    else Payment success
        break
    end
end

alt Payment failed
    Payment --> API : Payment declined
    API --> Web : Checkout failed
    Web --> Customer : Payment error
else Payment authorized
    Payment --> API : Authorization success
end

== Order Creation ==

API -> Order : Create order
Order -> DB : Persist order
DB --> Order : Order ID generated

Order -> Inventory : Reserve stock

alt Out of stock during reservation
    Inventory --> Order : Reservation failed

    Order -> Payment : Reverse authorization
    Payment --> Order : Refund initiated

    Order --> API : Order failed
    API --> Web : Item unavailable
else Reservation successful
    Inventory --> Order : Stock reserved
end

Order -> Shipping : Create shipment request
Shipping --> Order : Shipment scheduled

Order -> Bus : Publish OrderCreated event

== Asynchronous Event Processing ==

par Notifications
    Bus -> Notify : OrderCreated
    Notify -> Customer : Send email/SMS
else Analytics
    Bus -> Analytics : OrderCreated
    Analytics -> Analytics : Update dashboards
else Recommendations
    Bus -> Rec : OrderCreated
    Rec -> Rec : Update recommendation model
end

== Final Response ==

Order --> API : Order confirmed
API --> Web : 201 Created
Web --> Customer : Display confirmation page

@enduml