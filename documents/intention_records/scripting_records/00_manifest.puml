@startuml
title Scripting Diagram Atlas Manifest (Interconnected)
left to right direction
skinparam componentStyle rectangle

package "Atlas Root" {
  component "00_conventions.puml\nnotation, verbs, confidence tags" as CONV
}

package "Context Layer" {
  component "10_context_runtime_domains.puml" as C10
  component "11_context_authority_boundaries.puml" as C11
}

package "Structure Layer" {
  component "20_structure_script_file_types.puml" as S20
  component "21_structure_ctx_api_graph.puml" as S21
  component "22_structure_capability_channel_graph.puml" as S22
  component "23_structure_module_tree_model.puml" as S23
}

package "Flow Layer" {
  component "30_flow_bootstrap_pipeline.puml" as F30
  component "31_flow_entrypoint_loading_and_preprocess.puml" as F31
  component "32_flow_runtime_tick_orchestration.puml" as F32
}

package "Lifecycle Layer" {
  component "40_lifecycle_definition_and_freeze.puml" as L40
  component "41_lifecycle_intent_to_commit.puml" as L41
}

package "Decision Layer" {
  component "50_decision_contracts.puml" as D50
}

CONV -[#1E88E5]-> C10 : constrains naming + relation grammar within C10
CONV -[#1E88E5]-> C11 : constrains naming + relation grammar within C11
CONV -[#1E88E5]-> S20 : constrains naming + relation grammar within S20
CONV -[#1E88E5]-> S21 : constrains naming + relation grammar within S21
CONV -[#1E88E5]-> S22 : constrains naming + relation grammar within S22
CONV -[#1E88E5]-> S23 : constrains naming + relation grammar within S23
CONV -[#1E88E5]-> F30 : constrains naming + relation grammar within F30
CONV -[#1E88E5]-> F31 : constrains naming + relation grammar within F31
CONV -[#1E88E5]-> F32 : constrains naming + relation grammar within F32
CONV -[#1E88E5]-> L40 : constrains naming + relation grammar within L40
CONV -[#1E88E5]-> L41 : constrains naming + relation grammar within L41
CONV -[#1E88E5]-> D50 : constrains naming + relation grammar within D50

C10 -[#00897B]-> C11 : projects runtime-domain framing for authority-boundary view
C10 -[#00897B]-> S20 : projects runtime-domain framing for script-file-type structure
C10 -[#00897B]-> S22 : projects runtime-domain framing for channel-graph structure
C11 -[#1E88E5]-> S20 : constrains canonical definition scope within S20 contracts
C11 -[#1E88E5]-> S22 : constrains runtime authority scope within S22 contracts

S20 -[#00897B]-> S21 : supplies ctx profile anchors for ctx API graph
S20 -[#00897B]-> S23 : supplies folder-typing anchors for module-tree model
S21 -[#43A047]-> S22 : routes capability-intent semantics via channel graph
S23 -[#00897B]-> S20 : materializes typed file candidates for file-type contracts

S20 -[#FB8C00]-> F30 : drives bootstrap registration steps in F30
S23 -[#FB8C00]-> F31 : drives file/module discovery steps in F31
S21 -[#FB8C00]-> F32 : drives frame-time script interaction in F32
S22 -[#FB8C00]-> F32 : drives reconcile/apply semantics in F32

F30 -[#FB8C00]-> L40 : advances registration flow in definition lifecycle
F31 -[#FB8C00]-> L40 : feeds validation + sealing gates in definition lifecycle
F32 -[#FB8C00]-> L41 : advances runtime flow in intent lifecycle

D50 -[#1E88E5]-> S20 : locks file-typing contract semantics in S20
D50 -[#1E88E5]-> S21 : locks ctx-graph contract semantics in S21
D50 -[#1E88E5]-> S22 : locks channel contract semantics in S22
D50 -[#1E88E5]-> F30 : locks meta-bootstrap contract semantics in F30
D50 -[#1E88E5]-> F32 : locks runtime-orchestration semantics in F32
D50 -[#1E88E5]-> L40 : locks startup definition-seal semantics in L40
D50 -[#1E88E5]-> L41 : locks intent reconciliation semantics in L41

note bottom
The atlas is a graph, not a linear read order.
Each diagram intentionally intersects multiple layers.
end note
@enduml
